{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/.output/public" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/frontend/.output/server/index.mjs" },
    { "src": "/(.*)", "dest": "/frontend/.output/public/$1" }
  ]
}
